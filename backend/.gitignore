# =============================================================================
# ResumeIQ AI Backend — .gitignore
# =============================================================================

# ── Python ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ── Virtual Environment ───────────────────────────────────────────────
venv/
.venv/
env/

# ── Environment Variables ──────────────────────────────────────────────
.env

# ── IDE ────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Storage (uploaded files should not be committed) ───────────────────
storage/uploads/*
storage/processed/*
storage/temp/*
!storage/uploads/.gitkeep
!storage/processed/.gitkeep
!storage/temp/.gitkeep

# ── Legacy uploads directory ───────────────────────────────────────────
uploads/

# ── Testing ────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── OS ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── NLP Models (downloaded at runtime) ─────────────────────────────────
*.model
*.bin
